{
    "name": "bdx-swipe-menu-workspace",
    "private": true,
    "description": "Monorepo: @bdx/swipe-menu library + website",
    "packageManager": "pnpm@10.28.2",
    "pnpm": {
        "onlyBuiltDependencies": [
            "esbuild",
            "msw",
            "sharp"
        ]
    },
    "scripts": {
        "dev": "pnpm -C apps/website dev",
        "build": "pnpm -C apps/website build",
        "start": "pnpm -C apps/website start",
        "build:website": "pnpm -C apps/website build",
        "build:lib": "pnpm -C packages/swipe-menu build",
        "test": "pnpm -C apps/website test",
        "test:smoke": "pnpm -C apps/website test:smoke"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/gatocube/BdxSwipeMenu.git"
    },
    "license": "MIT"
}
