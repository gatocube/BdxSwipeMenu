{
  "name": "@bdx/website",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "node scripts/validate-public-env.mjs && pnpm -C ../../packages/swipe-menu build",
    "dev": "NEXT_PUBLIC_BASE_PATH= next dev -p 5174 --turbopack",
    "prebuild": "node scripts/validate-public-env.mjs && pnpm -C ../../packages/swipe-menu build",
    "build": "next build",
    "start": "next start -p 5174",
    "pretest": "node scripts/validate-public-env.mjs && pnpm -C ../../packages/swipe-menu build && npx playwright install chromium",
    "test": "npx playwright test",
    "pretest:smoke": "node scripts/validate-public-env.mjs && pnpm -C ../../packages/swipe-menu build",
    "test:smoke": "npx playwright test tests/smoke.e2e.ts"
  },
  "dependencies": {
    "@bdx/swipe-menu": "workspace:*",
    "@codemirror/autocomplete": "^6.20.0",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-yaml": "^6.1.2",
    "@codemirror/language": "^6.12.2",
    "@codemirror/lint": "^6.9.4",
    "@codemirror/state": "^6.5.4",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.39.15",
    "@uiw/react-codemirror": "^4.25.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "codemirror-json-schema": "^0.8.1",
    "framer-motion": "^12.34.3",
    "js-yaml": "^4.1.0",
    "lucide-react": "^0.575.0",
    "next": "^16.1.6",
    "radix-ui": "^1.4.3",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "25.3.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "postcss": "^8.5.6",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.9.3"
  }
