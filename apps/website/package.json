{
  "name": "@bdx/website",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "node scripts/validate-public-env.mjs && pnpm -C ../../packages/swipe-menu build",
    "dev": "NEXT_PUBLIC_BASE_PATH= next dev -p 5174 --turbopack",
    "prebuild": "node scripts/validate-public-env.mjs && pnpm -C ../../packages/swipe-menu build",
    "build": "next build",
    "start": "next start -p 5174",
    "pretest": "node scripts/validate-public-env.mjs && pnpm -C ../../packages/swipe-menu build && npx playwright install chromium",
    "test": "npx playwright test",
    "pretest:smoke": "node scripts/validate-public-env.mjs && pnpm -C ../../packages/swipe-menu build",
    "test:smoke": "npx playwright test tests/smoke.e2e.ts"
  },
  "dependencies": {
    "@bdx/swipe-menu": "workspace:*",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.34.3",
    "js-yaml": "^4.1.0",
    "lucide-react": "^0.575.0",
    "next": "^16.1.6",
    "radix-ui": "^1.4.3",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "25.3.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "postcss": "^8.5.6",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.9.3"
  }
}
