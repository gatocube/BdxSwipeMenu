# Dev server port
VITE_PORT=5177

# Local deployment
# IMPORTANT: this must be a PATH ONLY (no scheme/host/port), e.g. "/static/swipemenu".
# Do NOT set it to "http://bdx.gatocube.com:8090/static/swipemenu" or you may get mixed-content errors in production.
NEXT_PUBLIC_BASE_PATH=/static/swipemenu
DEPLOY_BASE=/static/swipemenu/
DEPLOY_PORT=8090
DEPLOY_PATH=~/www/bdx/static/swipemenu
DEPLOY_URL=https://bdx.gatocube.com
